{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "shared/components/ui/**"
  ],
  "printWidth": 120,
  "singleQuote": false,
  "semi": false,
  "jsxSingleQuote": false,
  "sortImports": {
    "newlinesBetween": true
  },
  "bracketSameLine": true,
  "sortTailwindcss": {
    "stylesheet": "./app/globals.css",
    "functions": [
      "clsx",
      "cn"
    ],
    "preserveWhitespace": false
  }
}
